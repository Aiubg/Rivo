# =========================================================================
# 1. Environment & Architecture
# =========================================================================

# Deployment target: local, vercel, cloudflare
DEPLOY_TARGET=local

# Database driver: libsql-local, libsql-remote
DB_DRIVER=libsql-local

# Storage driver: local-fs, s3
STORAGE_DRIVER=local-fs

# =========================================================================
# 2. Application Configuration
# =========================================================================

# Whether to allow anonymous chats (not saved to database)
PUBLIC_ALLOW_ANONYMOUS_CHATS=false

# =========================================================================
# 3. Database Configuration
# =========================================================================

# libsql URL (local: file:./data/app.db, production: libsql://...)
LIBSQL_URL=file:./data/app.db

# libsql Auth Token (required for libsql-remote)
LIBSQL_AUTH_TOKEN=

# =========================================================================
# 4. Storage Configuration
# =========================================================================

# --- Local Filesystem (local-fs) ---
LOCAL_UPLOAD_PUBLIC_PATH=/uploads
LOCAL_UPLOAD_STORAGE_ROOT=static/uploads

# --- S3-Compatible Object Storage (s3) ---
# Recommended for Vercel / Cloudflare
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
ASSET_PUBLIC_BASE_URL=

# =========================================================================
# 5. AI Model Providers API Keys
# =========================================================================

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=****

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=****

# Google Generative AI (https://aistudio.google.com/app/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=****

# DeepSeek (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=****

# xAI (https://console.x.ai/)
XAI_API_KEY=****

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=****

# OpenRouter (https://openrouter.ai/)
OPENROUTER_API_KEY=****
OPENROUTER_APP_NAME=Rivo
OPENROUTER_SITE_URL=****

# =========================================================================
# 6. Tool API Providers
# =========================================================================

# Tavily Search (https://app.tavily.com/)
TAVILY_API_KEY=****

# Wolfram Alpha AppID (https://developer.wolframalpha.com/)
WOLFRAM_ALPHA_APP_ID=****

# =========================================================================
# 7. Executor & Run Events Configuration
# =========================================================================

# Maximum concurrent AI execution tasks (1-8, default: 5)
RUN_EXECUTOR_MAX_CONCURRENCY=5

# Maximum characters for run event data (default: 60000)
RUN_EVENT_MAX_CHARS=60000

# Maximum characters for tool-specific event data (default: 20000)
RUN_EVENT_TOOL_MAX_CHARS=20000

# Maximum length for strings within event data (default: 4000)
RUN_EVENT_MAX_STRING_CHARS=4000

# Maximum length for arrays within event data (default: 30)
RUN_EVENT_MAX_ARRAY_LENGTH=30

# Maximum depth for nested objects within event data (default: 6)
RUN_EVENT_MAX_DEPTH=6
